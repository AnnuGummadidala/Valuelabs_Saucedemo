{
  "name": "valuelabs_project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf allure-results allure-report",
    "test:local": "npm run clean:allure && cross-env TEST_ENV=local playwright test && npm run allure:post",
    "test:staging": "npm run clean:allure && cross-env TEST_ENV=stage playwright test && npm run allure:post",
    "test:prod": "npm run clean:allure && cross-env TEST_ENV=prod playwright test && npm run allure:post",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:post": "npm run allure:generate && node ./scripts/openAllure.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.8.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "dotenv": "^17.4.2"
  }
}
